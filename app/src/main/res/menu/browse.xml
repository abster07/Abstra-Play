<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!--
        The Cast MediaRoute button.
        CastButtonFactory.setUpMediaRouteButton() in MainActivity attaches
        the correct Cast selector to this item automatically.
        The button is invisible until at least one Cast device is found on the network.
    -->
    <item
        android:id="@+id/media_route_menu_item"
        android:title="Cast"
        app:actionProviderClass="androidx.mediarouter.app.MediaRouteActionProvider"
        app:showAsAction="always" />

</menu>
